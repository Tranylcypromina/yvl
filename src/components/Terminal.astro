---
---
<section id="terminal-section" class="screen-terminal">
    <div class="terminal-bg-art">
        <div class="pixel-frame">
            <div class="pixel-shape"></div>
        </div>
    </div>

    <div class="terminal-large" id="terminalWindow">
        <div class="terminal-top-bar" id="terminalHeader">
            <div class="window-dots">
                <div class="dot"></div><div class="dot"></div><div class="dot"></div>
            </div>
            <div class="window-title" data-i18n="term_title">console.log</div>
            <div class="spacer-sm"></div>
        </div>
        
        <div id="terminalOutput" class="terminal-display"></div>
        
        <div class="input-line" id="inputTrigger">
            <span class="prompt">/</span>
            <input type="text" id="terminalInput" placeholder="RUN..." autocomplete="off">
        </div>
    </div>
</section>