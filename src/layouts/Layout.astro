---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YVL / SH</title>
    <meta name="description" content="El q quiera perdel su tiempo q lo pielda">
    <link rel="icon" href="/media/yvl.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Montserrat:wght@300;400;600;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body>
    <script is:inline>
        (function() {
            try {
                const theme = localStorage.getItem('yvl_theme');
                if (theme === 'dark') {
                    document.body.classList.add('dark-mode');
                }
            } catch (e) {}
        })();
    </script>

    <div class="noise-overlay"></div>
    <slot />
</body>
</html>