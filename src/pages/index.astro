---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import TelemetryGrid from '../components/TelemetryGrid.astro';
import VideoGrid from '../components/VideoGrid.astro';
import MindsTimeline from '../components/MindsTimeline.astro';

import I18N from '../data/i18n.json';
import DATA_STORE from '../data/store.json';
---

<Layout>
    <div class="mobile-blocker tabular-data">
        <h2 class="blocker-title">YVL<br>/ SH</h2>
        <div class="blocker-text">
            <p>Desktop only.</p>
        </div>
    </div>

    <div class="background-canvas tabular-data">
        <img src="/media/porsche_1.jpg" alt="Porsche GT3" class="bg-image">
        <div class="bg-overlay"></div>
    </div>

    <aside class="sidebar tabular-data">
        <div class="brand-block" id="btnReset">
            <h1 class="hero-title">YVL<br>/ SH</h1>
        </div>
        <nav class="nav-vertical">
            <button class="nav-main active" data-target="view-data" data-i18n="nav_data">01_DATA</button>
            <button class="nav-main" data-target="view-media" data-i18n="nav_media">02_VIDEO</button>
            <button class="nav-main" data-target="view-quotes" data-i18n="nav_quotes">03_LEGACY</button>
            <div class="nav-system">
                <div id="sysClock" class="nav-sm clock-box">00:00:00</div>
                <button id="langToggle" class="nav-sm">[ ES ]</button>
            </div>
            <div class="sys-message" id="sysMessage">You're going to die anyway</div>
        </nav>
    </aside>

    <main class="content-feed tabular-data">
        
        <div id="view-data" class="view-section active-view">
            <section class="screen-fold">
                <div class="grid-row header-row">
                    <div class="manifesto-box" id="profileCard">
                        <div class="box-header" id="profileHeader">
                            <div class="header-section primary" id="headerId">profile / 01</div>
                            <div class="header-section secondary" id="headerArchive">notes</div>
                            <div id="archiveLabel" class="header-section label-subtle">read somewhere</div>
                        </div>
                        <div class="manifesto-inner">
                            <p id="bioText" class="manifesto-text"></p>
                        </div>
                        <div class="box-footer">
                            <div class="footer-left">
                                <div class="footer-serial" id="footerSerial">yvl/notes/bird.txt</div>
                            </div>
                            <div class="footer-controls">
                                <div class="nav-arrows">
                                    <button id="btnPrevProfile" class="btn-arrow">&lt;</button>
                                    <button id="btnNextProfile" class="btn-arrow">&gt;</button>
                                    <button id="btnRewrite" class="btn-sync" data-i18n="btn_refresh">[ UPDATE ]</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <TelemetryGrid />
            </section>

            <section class="screen-archive" id="archive-section">
                <div class="archive-large" id="archiveWindow">
                    <div class="archive-top-bar" id="archiveHeader">
                        <div class="window-dots">
                            <div class="dot"></div>
                            <div class="dot"></div>
                            <div class="dot"></div>
                        </div>
                        <div class="window-title" id="archiveWindowTitle">DATABASE // YVL_LEGACY</div>
                    </div>
                    <div class="archive-body">
                        <div class="archive-sidebar" id="archiveIndex">
                        </div>
                        <div class="archive-content tabular-data">
                            <div class="archive-content-header" id="archiveContentTitle">WAITING FOR CONNECTION...</div>
                            <div class="archive-text-area" id="archiveViewer">
                                > Select a document from the archive.
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <div id="view-media" class="view-section">
            <VideoGrid />
        </div>

        <div id="view-quotes" class="view-section">
            <MindsTimeline />
        </div>

        <footer class="grid-footer">
            <div class="footer-link-group">
                <a href="https://www.instagram.com/tranylcypromina" target="_blank" rel="noopener noreferrer" class="link">IG</a>
                <a href="mailto:contact@yvl.sh" class="link" data-i18n="link_mail">MAIL</a>
            </div>
            <div class="footer-meta">OPEN SOURCE // 2026</div>
        </footer>
    </main>

    <script define:vars={{ I18N, DATA_STORE }}>
        const CONFIG = { typingSpeed: 1, animDuration: 600, scrollDuration: 800 };

        const ARCHIVE_I18N = {
            en: {
                waiting: "WAITING FOR CONNECTION...",
                select: "> Select a document from the archive.",
                title: "DATABASE // YVL_LEGACY",
                dump_init: "[ INITIATING TELEMETRY DUMP: ",
                dump_end: "[ DUMP COMPLETED ]",
                id: "IDENTIFICATION: ",
                sys_msg: "You're going to die anyway"
            },
            es: {
                waiting: "ESPERANDO CONEXIÓN...",
                select: "> Selecciona un archivo del índice.",
                title: "BASE DE DATOS // LEGADO_YVL",
                dump_init: "[ INICIANDO VOLCADO DE TELEMETRÍA: ",
                dump_end: "[ VOLCADO COMPLETADO ]",
                id: "IDENTIFICACIÓN: ",
                sys_msg: "Vas a morir de todos modos"
            }
        };

        const ARCHIVE_DB = {
            en: [
                { id: "DOC_01", title: "THE_ORIGIN.TXT", content: "We didn't start this to fit in.\n\nEvery scratch on the chassis is a lesson learned. The obsession with perfection isn't about looking good under dealership lights. It's about not falling apart when you push the machine into the abyss.\n\nLegacy is built in the dark, far away from the cameras." },
                { id: "DOC_02", title: "FLAT_SIX_TEARDOWN.LOG", content: "Engine block dismantled at 03:00 AM.\n\nTolerances measured in microns. When you look inside a high-performance engine, you realize it's just a vessel for controlled violence. Thousands of explosions per minute, contained within a block of cold aluminum.\n\nIf it doesn't sound dangerous, you are doing it wrong." },
                { id: "DOC_03", title: "NIGHT_DRIVE.MD", content: "Empty highways. Oil temperature optimal.\n\nThere is a specific moment at 200 km/h where the noise of the world disappears entirely. The only metric that matters is the mechanical connection between flesh and metal.\n\nNo screens. No driver assists. Just raw, unfiltered telemetry." }
            ],
            es: [
                { id: "DOC_01", title: "EL_ORIGEN.TXT", content: "No empezamos esto para encajar.\n\nCada cicatriz en el chasis es una lección aprendida. La obsesión por la perfección no trata de lucir bien bajo las luces de un concesionario. Trata de no desmoronarte cuando empujas la máquina hacia el abismo.\n\nEl legado se construye en la oscuridad, lejos de las cámaras." },
                { id: "DOC_02", title: "DESMONTAJE_FLAT_SIX.LOG", content: "Bloque motor desmontado a las 03:00 AM.\n\nTolerancias medidas en micras. Cuando miras dentro de un motor de alto rendimiento, te das cuenta de que es solo un recipiente para la violencia controlada. Miles de explosiones por minuto contenidas en un bloque de aluminio frío.\n\nSi no suena peligroso, lo estás haciendo mal." },
                { id: "DOC_03", title: "CONDUCCION_NOCTURNA.MD", content: "Autopistas vacías. Temperatura del aceite óptima.\n\nHay un momento específico a 200 km/h donde el ruido del mundo desaparece por completo. La única métrica que importa es la conexión mecánica entre la carne y el metal.\n\nSin pantallas. Sin asistencias de conducción. Solo telemetría cruda y sin filtros." }
            ]
        };

        const Utils = {
            wait: (ms) => new Promise(resolve => setTimeout(resolve, ms)),
            typeText: (element, text, speed = 1) => {
                const currentRequestId = Math.random().toString(36).substring(2, 9);
                element.dataset.typeId = currentRequestId;
                if (speed === 0) { element.textContent = text; return Promise.resolve(); }
                return new Promise(resolve => {
                    element.textContent = ''; let i = 0;
                    const type = () => {
                        if (element.dataset.typeId !== currentRequestId) { resolve(); return; }
                        if (i < text.length) { element.textContent += text.charAt(i); i++; setTimeout(type, speed + (Math.random() * 4)); } 
                        else { resolve(); }
                    };
                    type();
                });
            },
            scrollTo: (element, duration = 1000) => {
                if (!element) return;
                const targetPos = element.getBoundingClientRect().top + window.pageYOffset;
                const startPos = window.pageYOffset; const distance = targetPos - startPos; let startTime = null;
                function animation(currentTime) {
                    if (startTime === null) startTime = currentTime;
                    const timeElapsed = currentTime - startTime; let run; let t = timeElapsed / (duration / 2);
                    if (t < 1) run = distance / 2 * Math.pow(2, 10 * (t - 1)) + startPos; 
                    else { t--; run = distance / 2 * (-Math.pow(2, -10 * t) + 2) + startPos; }
                    window.scrollTo(0, run);
                    if (timeElapsed < duration) requestAnimationFrame(animation);
                }
                requestAnimationFrame(animation);
            }
        };

        const ArchiveSystem = {
            init() {
                this.indexContainer = document.getElementById('archiveIndex');
                this.titleElement = document.getElementById('archiveContentTitle');
                this.viewerElement = document.getElementById('archiveViewer');
                this.windowTitle = document.getElementById('archiveWindowTitle');
                if (!this.indexContainer || !this.viewerElement) return;
                this.renderIndex();
            },
            renderIndex() {
                this.indexContainer.innerHTML = '';
                const currentDocs = ARCHIVE_DB[App.state.lang] || ARCHIVE_DB['en'];
                
                currentDocs.forEach((doc) => {
                    const btn = document.createElement('button');
                    btn.className = 'archive-file-btn';
                    btn.textContent = `[ ${doc.id} ] - ${doc.title}`;
                    btn.onclick = () => this.loadFile(doc.title, doc.content, btn);
                    this.indexContainer.appendChild(btn);
                });

                const t = ARCHIVE_I18N[App.state.lang];
                this.titleElement.textContent = t.waiting;
                this.viewerElement.textContent = t.select;
                this.windowTitle.textContent = t.title;
            },
            async loadFile(title, content, btnElement = null) {
                document.querySelectorAll('.archive-file-btn').forEach(b => b.classList.remove('active'));
                if (btnElement) btnElement.classList.add('active');
                
                const readingPrefix = App.state.lang === 'es' ? 'LEYENDO: ' : 'READING: ';
                this.titleElement.textContent = `${readingPrefix}${title}`;
                await Utils.typeText(this.viewerElement, content, 2);
            }
        };

        const QuotesSystem = {
            init() { this.render(); },
            render(animate = false) {
                const container = document.getElementById('quotesContainer');
                if(!container) return; container.innerHTML = '<div class="spine"></div>';
                const data = DATA_STORE[App.state.lang].QUOTES;
                data.forEach((q, i) => {
                    const node = document.createElement('div');
                    node.className = `q-node ${i % 2 === 0 ? 'left' : 'right'}`;
                    if (animate) node.classList.add('lang-shifting');
                    node.innerHTML = `<div class="q-marker"></div><div class="q-meta">${q.id} // ${q.author}</div><div class="q-text">${q.text}</div><div class="q-expanded-container"><div class="q-expanded"></div></div>`;
                    node.addEventListener('click', () => this.handleClick(q, node));
                    container.appendChild(node);
                    if (animate) { setTimeout(() => { node.classList.remove('lang-shifting'); node.classList.add('lang-shifted'); setTimeout(() => node.classList.remove('lang-shifted'), 400); }, 200 + (i * 50)); }
                });
            },
            handleClick(q, nodeElement) {
                const isAlreadyActive = nodeElement.classList.contains('active-quote');
                document.querySelectorAll('.q-node').forEach(n => { n.classList.remove('active-quote'); const cont = n.querySelector('.q-expanded-container'); if(cont) cont.classList.remove('open'); });
                if (isAlreadyActive) return;
                nodeElement.classList.add('active-quote');
                const cont = nodeElement.querySelector('.q-expanded-container'); const exp = nodeElement.querySelector('.q-expanded');
                exp.innerHTML = '';
                if (q.expandedLogs && q.expandedLogs.length > 0) { q.expandedLogs.forEach((text, i) => { const line = document.createElement('div'); line.className = 'q-log-line'; line.textContent = text; line.style.animationDelay = `${i * 0.08}s`; exp.appendChild(line); }); } else { const line = document.createElement('div'); line.className = 'q-log-line'; line.textContent = q.text; exp.appendChild(line); }
                void cont.offsetWidth; cont.classList.add('open');
            }
        };

        const App = {
            state: { lang: 'en', profileIndex: 0, textVariant: 0, activeCarId: null },
            elements: {},
            init() {
                const savedLang = localStorage.getItem('yvl_lang'); 
                if (savedLang && (savedLang === 'en' || savedLang === 'es')) { this.state.lang = savedLang; }
                this.cacheDOM(); this.bindEvents(); if(this.bindDraggables) this.bindDraggables(); 
                this.applyTranslations(false); this.updateLangButton();
                document.body.classList.add('dark-mode'); 
                this.renderProfile(false); QuotesSystem.init(); ArchiveSystem.init(); 
                this.bindVideoLogic(); this.initClock(); 
            },
            cacheDOM() {
                this.elements = { 
                    body: document.body, btnLang: document.getElementById('langToggle'), btnPrev: document.getElementById('btnPrevProfile'), 
                    btnNext: document.getElementById('btnNextProfile'), btnRewrite: document.getElementById('btnRewrite'), bioText: document.getElementById('bioText'), 
                    profileCard: document.getElementById('profileCard'), profileHeader: document.getElementById('profileHeader'), archiveWindow: document.getElementById('archiveWindow'), 
                    archiveHeader: document.getElementById('archiveHeader'), viewSection: document.getElementById('view-data'), brandTitle: document.querySelector('.brand-block'), 
                    sysClock: document.getElementById('sysClock'), sysMessage: document.getElementById('sysMessage')
                };
            },
            bindEvents() {
                document.querySelectorAll('.nav-main').forEach(btn => { btn.addEventListener('click', (e) => this.handleNav(e)); });
                if(this.elements.brandTitle) { this.elements.brandTitle.addEventListener('click', () => { window.location.href = '/'; }); }
                this.elements.btnLang.addEventListener('click', () => this.toggleLang());
                this.elements.btnNext.addEventListener('click', () => this.cycleProfile(1));
                this.elements.btnPrev.addEventListener('click', () => this.cycleProfile(-1));
                this.elements.btnRewrite.addEventListener('click', () => { this.state.textVariant++; this.renderProfile(); });
                document.querySelectorAll('.data-item').forEach(item => { item.addEventListener('click', () => this.handleDataRequest(item)); });

                window.addEventListener('keydown', (e) => {
                    const key = e.key.toLowerCase();
                    if (key === '1') document.querySelector('[data-target="view-data"]')?.click();
                    else if (key === '2') document.querySelector('[data-target="view-media"]')?.click();
                    else if (key === '3') document.querySelector('[data-target="view-quotes"]')?.click();
                });
            },
            bindDraggables() {
                const makeDraggable = (el, handle) => {
                    if (!el || !handle) return;
                    let isDragging = false, start = { x: 0, y: 0 }, offset = { x: 0, y: 0 }; 
                    handle.addEventListener('mousedown', (e) => { 
                        if (window.innerWidth <= 768) return; 
                        isDragging = true; start.x = e.clientX - offset.x; start.y = e.clientY - offset.y; 
                        el.style.transition = 'none'; el.style.zIndex = 100; 
                    });
                    document.addEventListener('mouseup', () => { 
                        if (!isDragging) return; isDragging = false; 
                        el.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)'; el.style.transform = `translate3d(0px, 0px, 0)`; offset = { x: 0, y: 0 }; 
                    });
                    document.addEventListener('mousemove', (e) => { 
                        if (!isDragging) return; e.preventDefault(); 
                        const currentX = e.clientX - start.x; const currentY = e.clientY - start.y; 
                        if (Math.abs(currentX) < window.innerWidth && Math.abs(currentY) < window.innerHeight) { 
                            offset.x = currentX; offset.y = currentY; el.style.transform = `translate3d(${currentX}px, ${currentY}px, 0)`; 
                        } 
                    });
                };
                makeDraggable(this.elements.profileCard, this.elements.profileHeader); 
                makeDraggable(this.elements.archiveWindow, this.elements.archiveHeader);
            },
            bindVideoLogic() {
                const screens = document.querySelectorAll('.monitor-screen');
                screens.forEach(screen => {
                    const overlay = screen.querySelector('.video-overlay');
                    const videoEl = screen.querySelector('video');
                    if(overlay && videoEl) {
                        overlay.addEventListener('click', () => {
                            const playPromise = videoEl.play();
                            if (playPromise !== undefined) playPromise.catch(e => console.log("Video Error:", e)); 
                        });
                    }
                    if(videoEl) {
                        videoEl.addEventListener('play', () => {
                            screen.classList.add('active-signal'); 
                            document.querySelectorAll('video').forEach(otherVideo => { if (otherVideo !== videoEl && !otherVideo.paused) otherVideo.pause(); });
                        });
                    }
                });
            },
            initClock() {
                const update = () => { 
                    const now = new Date(); 
                    if(this.elements.sysClock) this.elements.sysClock.textContent = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' }); 
                };
                update(); setInterval(update, 1000);
            },
            async handleDataRequest(item) {
                const carId = item.dataset.carId; this.state.activeCarId = carId;
                
                document.querySelectorAll('.data-item').forEach(i => i.classList.remove('active-selection'));
                item.classList.add('active-selection');
                Utils.scrollTo(document.getElementById('archive-section'), CONFIG.scrollDuration);
                
                const langObj = I18N[this.state.lang];
                const tUI = ARCHIVE_I18N[this.state.lang];
                const carData = DATA_STORE[this.state.lang].CARS[carId];
                
                let dumpText = `${tUI.dump_init}${carId} ]\n`;
                dumpText += `${tUI.id}${carData.NAME || carData.NOMBRE}\n===========================================\n\n`;
                if (carData.STATS) {
                    for (const [key, value] of Object.entries(carData.STATS)) {
                        const label = langObj.KEY_MAP?.[key] || key;
                        dumpText += `> ${label.padEnd(20, '.')} ${value}\n`;
                    }
                }
                dumpText += `\n${tUI.dump_end}`;
                ArchiveSystem.loadFile(`TELEMETRY_${carId}.DAT`, dumpText);
            },
            cycleProfile(dir) {
                const profiles = DATA_STORE[this.state.lang].PROFILES; this.state.profileIndex += dir; this.state.textVariant = 0; 
                if (this.state.profileIndex >= profiles.length) this.state.profileIndex = 0; 
                if (this.state.profileIndex < 0) this.state.profileIndex = profiles.length - 1; 
                this.renderProfile(); 
            },
            renderProfile(animate = true) {
                const p = DATA_STORE[this.state.lang].PROFILES[this.state.profileIndex]; const t = I18N[this.state.lang]; const currentText = p.texts[this.state.textVariant % p.texts.length];
                document.getElementById('headerId').textContent = t.label_id + p.id; document.getElementById('headerArchive').textContent = t.label_archive; 
                document.getElementById('footerSerial').textContent = t.footer_serial + p.path; document.getElementById('archiveLabel').textContent = t.label_source + p.source;
                Utils.typeText(this.elements.bioText, currentText, animate ? 10 : 0);
            },
            updateLangButton() { 
                this.elements.btnLang.textContent = this.state.lang === 'en' ? '[ ES ]' : '[ ENG ]'; 
                if (this.elements.sysMessage) {
                    this.elements.sysMessage.textContent = ARCHIVE_I18N[this.state.lang].sys_msg;
                }
            },
            applyTranslations(animate = true) {
                const elements = document.querySelectorAll('[data-i18n]');
                elements.forEach(el => {
                    if (animate) {
                        el.classList.add('i18n-fade'); 
                        setTimeout(() => { const key = el.dataset.i18n; if (I18N[this.state.lang][key]) el.textContent = I18N[this.state.lang][key]; el.classList.remove('i18n-fade'); }, 200);
                    } else { const key = el.dataset.i18n; if (I18N[this.state.lang][key]) el.textContent = I18N[this.state.lang][key]; }
                });
            },
            toggleLang() {
                const newLang = this.state.lang === 'en' ? 'es' : 'en'; this.state.lang = newLang; localStorage.setItem('yvl_lang', newLang);
                this.updateLangButton(); this.applyTranslations(true); this.renderProfile(false); QuotesSystem.render(true);
                ArchiveSystem.renderIndex(); 
            },
            handleNav(e) {
                document.querySelectorAll('.nav-main').forEach(b => b.classList.remove('active')); e.target.classList.add('active');
                const targetId = e.target.dataset.target;
                
                document.querySelectorAll('.view-section').forEach(sec => { 
                    sec.classList.remove('active-view'); 
                    if (sec.id === targetId) sec.classList.add('active-view'); 
                });
                
                window.scrollTo(0, 0);
                
                document.querySelectorAll('.monitor-screen').forEach(screen => {
                    if (screen.classList.contains('active-signal')) { 
                        screen.classList.remove('active-signal'); const videoEl = screen.querySelector('video'); 
                        if (videoEl) { videoEl.pause(); videoEl.currentTime = 0; } 
                    }
                });
            }
        };

        document.addEventListener('DOMContentLoaded', () => App.init());
    </script>
</Layout>